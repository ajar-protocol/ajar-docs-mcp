{
  "ajar_version": "0.1",
  "supported_versions": ["0.1"],
  "profiles": ["CORE", "ACT", "PAY"],
  "site": {
    "name": "Thistledown Seed Exchange",
    "domain": "thistledown-seeds.example",
    "description": "Heirloom and open-pollinated seed exchange: a searchable living catalog of regionally adapted seed lots, temporary lot reservations for growers, and purchase of curated seed bundles with germination-alert subscriptions.",
    "languages": ["en", "en-GB", "cy"],
    "legal_entity": "Thistledown Seed Exchange CIC",
    "contact": "agents@thistledown-seeds.example"
  },
  "x-thistledown-grower-network": "https://thistledown-seeds.example/growers",
  "keys": {
    "owner": {
