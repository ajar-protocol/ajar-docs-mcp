          "x": "B2KAkcBrufgEHVSUBPNyejV0dMp_2zmcsAs1g9pVmpo",
          "kid": "thistledown-ops-2026-q3"
        },
        "scope": ["content-signing", "offer-signing", "receipt-signing"],
        "valid_until": "2026-09-30T00:00:00Z",
