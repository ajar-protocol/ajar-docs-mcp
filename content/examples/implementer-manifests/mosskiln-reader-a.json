  "actions": [
    {
      "id": "search_catalog",
      "title": "Search catalog",
      "risk": "R0",
      "input_schema": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 10
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "sku",
                "name",
                "price"
              ],
              "properties": {
                "sku": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "price": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      },
      "effects": [],
      "preconditions": [],
      "simulate": false,
      "execution": "direct",
      "idempotency": "optional",
      "requires": {
        "tier": "anonymous",
        "mandate_scopes": [
          "content.read.product"
        ]
      },
      "pricing": {
        "per_call": "0",
        "settlement_on_commit": false
      },
      "endpoint": "/ajar/actions/search_catalog",
      "transport": "ajar-http"
    },
    {
      "id": "add_item_to_cart",
      "title": "Add item to cart",
      "risk": "R1",
      "input_schema": {
        "type": "object",
        "required": [
          "sku",
          "quantity"
        ],
        "properties": {
          "sku": {
            "type": "string",
            "pattern": "^[A-Z0-9-]{3,32}$"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": [
          "cart_id",
          "line_id",
          "subtotal"
        ],
        "properties": {
          "cart_id": {
            "type": "string"
          },
          "line_id": {
            "type": "string"
          },
          "subtotal": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "effects": [
        {
          "type": "resource.create",
          "resource": "cart_line",
          "reversible_until": "P30D"
        }
      ],
      "preconditions": [
        "catalog_item_available"
      ],
      "simulate": true,
      "execution": "direct",
      "idempotency": "required",
      "requires": {
        "tier": "signed",
        "mandate_scopes": [
          "commerce.cart.modify"
        ]
      },
      "pricing": {
        "per_call": "0",
        "settlement_on_commit": false
      },
      "endpoint": "/ajar/actions/add_item_to_cart",
      "transport": "ajar-http"
    },
    {
      "id": "purchase_goods",
      "title": "Purchase garden supplies",
      "risk": "R3",
      "input_schema": {
        "type": "object",
        "required": [
          "cart_id",
          "shipping_address_id",
          "max_total"
        ],
        "properties": {
          "cart_id": {
            "type": "string",
            "minLength": 1
          },
          "shipping_address_id": {
            "type": "string",
            "minLength": 1
          },
          "max_total": {
            "type": "object",
            "required": [
              "currency",
              "amount"
            ],
            "properties": {
              "currency": {
                "type": "string",
                "const": "USD"
              },
              "amount": {
                "type": "string",
                "pattern": "^[0-9]+(\\.[0-9]{2})?$"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": [
          "order_id",
          "total_cost",
          "receipt_id"
        ],
        "properties": {
          "order_id": {
            "type": "string"
          },
          "total_cost": {
            "type": "object",
            "required": [
              "currency",
              "amount"
            ],
            "properties": {
              "currency": {
                "type": "string",
                "const": "USD"
              },
              "amount": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "receipt_id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "effects": [
        {
          "type": "financial.charge",
          "currency": "USD",
          "max": "500.00"
        },
        {
          "type": "resource.create",
          "resource": "order",
          "reversible_until": "P1D"
        }
      ],
      "preconditions": [
        "cart_not_empty",
        "inventory_available",
        "shipping_address_valid",
        "settlement_authorized"
      ],
      "simulate": true,
      "execution": "two_phase",
      "idempotency": "required",
      "requires": {
        "tier": "verified",
        "mandate_scopes": [
