  "actions": [
    {
      "id": "search_routes",
      "title": "Search train routes",
      "risk": "R0",
      "input_schema": {
        "type": "object",
        "required": ["from", "to", "date"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "date": { "type": "string", "format": "date" }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["routes"],
        "properties": {
          "routes": { "type": "array" }
        }
      },
      "effects": [],
      "simulate": false,
      "execution": "direct",
      "idempotency": "none",
      "requires": {
        "tier": "anonymous"
      },
      "pricing": {
        "per_call": "0",
        "settlement_on_commit": false
      },
      "endpoint": "/ajar/actions/search_routes",
      "transport": "ajar-http"
    },
    {
      "id": "purchase_tickets",
      "title": "Purchase train tickets",
      "risk": "R3",
      "input_schema": {
        "type": "object",
        "required": ["route_id", "passengers", "travel_class"],
        "properties": {
          "route_id": { "type": "string" },
          "passengers": { "type": "integer", "minimum": 1, "maximum": 50 },
          "travel_class": { "type": "string", "enum": ["sleeper", "chair", "business"] }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "required": ["booking_id", "tickets"],
        "properties": {
          "booking_id": { "type": "string" },
          "tickets": { "type": "integer" }
        }
      },
      "effects": [
        {
          "type": "financial.charge",
          "currency": "INR",
          "max": "computed"
        },
        {
          "type": "resource.create",
          "resource": "booking",
          "reversible_until": "P2D"
        }
      ],
      "preconditions": ["seat_availability"],
      "simulate": true,
      "execution": "two_phase",
      "idempotency": "required",
      "requires": {
        "tier": "verified",
        "mandate_scopes": ["commerce.purchase.transport"]
      },
      "pricing": {
        "per_call": "0",
        "settlement_on_commit": true
      },
      "endpoint": "/ajar/actions/purchase_tickets",
      "transport": "ajar-http"
    }
