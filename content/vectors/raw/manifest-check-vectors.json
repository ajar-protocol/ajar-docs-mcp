{
  "ajar_version": "0.1",
  "vectors": [
    {
      "id": "manifest-check-blog-valid",
      "manifest": "examples/manifests/blog-core.json",
      "served_path": "/.well-known/ajar.json",
      "expected": {
        "valid": true
      }
    },
    {
      "id": "manifest-check-commerce-valid",
      "manifest": "examples/manifests/commerce-core-act-pay.json",
      "served_path": "/.well-known/ajar.json",
      "expected": {
        "valid": true
      }
    },
    {
      "id": "manifest-check-wrong-served-path",
      "manifest": "examples/manifests/blog-core.json",
      "served_path": "/ajar.json",
      "expected": {
        "valid": false,
        "contains": "AJAR-MANIFEST-LOCATION"
      }
    },
    {
      "id": "manifest-check-risk-floor-invalid",
      "manifest": "examples/invalid/risk-floor/manifest.json",
      "served_path": "/.well-known/ajar.json",
      "expected": {
        "valid": false,
        "contains": "two_phase"
      }
    },
    {
      "id": "manifest-check-expired-invalid",
      "manifest": "examples/invalid/expired-manifest/manifest.json",
      "served_path": "/.well-known/ajar.json",
      "expected": {
        "valid": false,
        "contains": "AJAR-VERIFY-EXPIRED"
      }
    },
    {
      "id": "manifest-check-lifetime-over-180d-invalid",
      "manifest": "examples/invalid/manifest-lifetime-over-180d/manifest.json",
      "served_path": "/.well-known/ajar.json",
      "expected": {
        "valid": false,
        "contains": "AJAR-VERIFY-EXPIRED"
      }
    }
  ]
}
