{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.ajarprotocol.org/schemas/manifest.schema.json",
  "title": "Ajar Capability Manifest",
  "$comment": "docs/03-PROTOCOL-SPEC.md sections 2 and 3.",
  "type": "object",
  "required": [
    "ajar_version",
    "supported_versions",
    "profiles",
    "site",
    "keys",
    "views",
    "policy_summary",
    "issued_at",
    "expires_at",
    "sequence",
    "signature"
  ],
  "properties": {
    "ajar_version": { "$ref": "common.schema.json#/$defs/ajar_version" },
    "supported_versions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.schema.json#/$defs/ajar_version" }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "common.schema.json#/$defs/profile" }
    },
    "site": {
      "type": "object",
      "required": ["name", "domain", "description", "languages", "contact"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z]{2,3}(-[A-Z]{2})?$" }
        },
        "legal_entity": { "type": "string" },
        "contact": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "keys": {
      "type": "object",
      "required": ["owner", "operational"],
      "properties": {
        "owner": { "$ref": "common.schema.json#/$defs/jwk_ed25519" },
        "operational": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "scope", "valid_until", "certification"],
            "properties": {
              "key": { "$ref": "common.schema.json#/$defs/jwk_ed25519" },
              "scope": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "enum": ["content-signing", "offer-signing", "receipt-signing"] }
              },
              "valid_until": { "$ref": "common.schema.json#/$defs/date_time" },
              "certification": { "$ref": "common.schema.json#/$defs/signature" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "views": {
      "type": "object",
      "required": ["negotiation", "index", "chunking", "license"],
      "properties": {
        "negotiation": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["application/ajar+json", "text/markdown"] }
        },
        "index": { "$ref": "common.schema.json#/$defs/uri_reference" },
        "chunking": {
          "type": "object",
          "required": ["stable_ids", "diff"],
          "properties": {
            "stable_ids": { "type": "boolean" },
            "diff": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "license": {
          "type": "object",
          "required": ["read", "train"],
          "properties": {
            "read": { "type": "string", "enum": ["allowed", "denied", "metered"] },
            "train": { "type": "string", "enum": ["allowed", "denied", "metered"] },
            "terms": { "$ref": "common.schema.json#/$defs/uri_reference" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "action.schema.json" }
    },
    "policy_summary": {
      "type": "object",
      "required": ["audience_tiers", "rate_limits", "requires_mandate_from_risk"],
      "properties": {
        "audience_tiers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["anonymous", "signed", "verified", "allowlist", "contracted"] }
        },
        "rate_limits": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "requires_mandate_from_risk": { "type": "string", "enum": ["R0", "R1", "R2"] }
      },
      "additionalProperties": false
    },
    "metering": {
      "type": "object",
      "required": ["currency", "settlement", "endpoint_402"],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "read": { "type": "object", "additionalProperties": { "type": "string" } },
        "settlement": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,40}$" }
        },
        "endpoint_402": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "federation": {
      "type": "object",
      "required": ["logs"],
      "properties": {
        "logs": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/https_uri" }
        },
        "latest_sth": { "type": "string" }
      },
      "additionalProperties": false
    },
    "issued_at": { "$ref": "common.schema.json#/$defs/date_time" },
    "expires_at": { "$ref": "common.schema.json#/$defs/date_time" },
    "sequence": { "type": "integer", "minimum": 0 },
    "signature": { "$ref": "common.schema.json#/$defs/signature" }
  },
  "allOf": [
    {
      "if": { "properties": { "profiles": { "contains": { "const": "ACT" } } }, "required": ["profiles"] },
      "then": { "required": ["actions"] }
    },
    {
      "if": { "properties": { "profiles": { "contains": { "const": "PAY" } } }, "required": ["profiles"] },
      "then": { "required": ["metering"] }
    }
  ],
  "patternProperties": {
    "^x-[a-z0-9-]+-.+$": true
  },
  "additionalProperties": false
}
