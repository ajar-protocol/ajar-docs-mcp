{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.ajarprotocol.org/schemas/offer.schema.json",
  "title": "Ajar Offer",
  "$comment": "docs/03-PROTOCOL-SPEC.md section 7.",
  "type": "object",
  "required": ["ajar_version", "type", "offer_id", "action_id", "input_hash", "resolved_effects", "total_cost", "issued_at", "expires_at", "signature"],
  "properties": {
    "ajar_version": { "$ref": "common.schema.json#/$defs/ajar_version" },
    "type": { "const": "offer" },
    "offer_id": { "type": "string", "pattern": "^urn:uuid:[0-9a-fA-F-]{36}$" },
    "action_id": { "type": "string", "minLength": 1 },
    "input_hash": { "type": "string", "pattern": "^sha256:[A-Za-z0-9_-]+$" },
    "resolved_effects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.schema.json#/$defs/effect" }
    },
    "total_cost": { "$ref": "common.schema.json#/$defs/money" },
    "issued_at": { "$ref": "common.schema.json#/$defs/date_time" },
    "expires_at": { "$ref": "common.schema.json#/$defs/date_time" },
    "single_use": { "type": "boolean", "default": true },
    "signature": { "$ref": "common.schema.json#/$defs/signature" }
  },
  "patternProperties": {
    "^x-[a-z0-9-]+-.+$": true
  },
  "additionalProperties": false
}
