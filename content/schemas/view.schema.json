{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec.ajarprotocol.org/schemas/view.schema.json",
  "title": "Ajar View",
  "$comment": "docs/03-PROTOCOL-SPEC.md section 4.",
  "type": "object",
  "required": ["ajar_version", "url", "content_type", "etag", "chunks", "signature"],
  "properties": {
    "ajar_version": { "$ref": "common.schema.json#/$defs/ajar_version" },
    "url": { "type": "string", "minLength": 1 },
    "content_type": { "const": "application/ajar+json" },
    "etag": { "type": "string", "minLength": 1 },
    "language": { "type": "string" },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "content", "hash"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-zA-Z0-9_.:-]+$" },
          "type": { "type": "string", "enum": ["heading", "paragraph", "list", "table", "product", "action_hint", "metadata"] },
          "content": { "type": "string" },
          "hash": { "type": "string", "pattern": "^sha256:[A-Za-z0-9_-]+$" },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["href"],
              "properties": {
                "href": { "type": "string", "minLength": 1 },
                "rel": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "signature": { "$ref": "common.schema.json#/$defs/signature" }
  },
  "patternProperties": {
    "^x-[a-z0-9-]+-.+$": true
  },
  "additionalProperties": false
}
